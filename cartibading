-- This script is formatted specifically for an Executor environment
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- The fake ban text message
local banMessage = "\n" ..
	"Your account has been permanently suspended from this experience.\n\n" ..
	"Reason: Exploiting / Item Duplication (Dupe Glitch)\n" ..
	"Action Taken: Account Terminated (Server Restriction)\n" ..
	"Log Reference: #ERR-9942A\n\n" ..
	"If you believe this was an error, please contact the experience developers."

-- In an executor, LocalPlayer is always available instantly
if LocalPlayer then
    LocalPlayer:Kick(banMessage)
else
    warn("Could not find LocalPlayer instance.")
end
